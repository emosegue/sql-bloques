# ─────────────────────────────────────────────────────────────────────────────
# SQL Bloques — Environment Configuration
# Copy this file to .env and fill in the values before running docker compose.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root_password
MYSQL_USER=sqlbloques
MYSQL_PASSWORD=changeme_app_password

# ── BFF ───────────────────────────────────────────────────────────────────────
# Shared secret between the frontend and BFF. Change this to any random string.
# Generate one with: openssl rand -hex 32
API_TOKEN=changeme_api_token

# ── URL base path ─────────────────────────────────────────────────────────────
# Leave empty (or /) to serve at the domain root: http://servidor.edu/
# Set to a subpath to serve at a subdirectory: http://www.universidad.com/sqlbloques
#
# IMPORTANT: changing BASE_PATH requires a full rebuild of the nginx/frontend image:
#   docker compose up -d --build nginx
#
BASE_PATH=

# ── HTTPS (optional) ──────────────────────────────────────────────────────────
# To enable HTTPS, mount your certificate files into the nginx container and
# update the nginx config. Two options:
#
# Option A — Institutional certificate (team provides .crt and .key):
#   1. Place the files at:  infra/certs/server.crt  and  infra/certs/server.key
#   2. Add to nginx service in docker-compose.yml:
#        volumes:
#          - ./infra/certs/server.crt:/etc/nginx/certs/server.crt:ro
#          - ./infra/certs/server.key:/etc/nginx/certs/server.key:ro
#   3. Update frontend/nginx.conf.template to add an SSL server block.
#
# Option B — Let's Encrypt / Certbot (requires a public domain):
#   Run:  docker compose run --rm certbot certonly --webroot -d your.domain.com
#   Then uncomment the certbot service in docker-compose.yml.
